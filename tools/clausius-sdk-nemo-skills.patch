     return cmd
 
 
+def _clausius_env_vars():
+    """Collect Clausius SDK env vars to inject into the container."""
+    env = {}
+    url = os.environ.get("CLAUSIUS_URL", "")
+    if url:
+        env["CLAUSIUS_URL"] = url
+        token = os.environ.get("CLAUSIUS_TOKEN", "")
+        if token:
+            env["CLAUSIUS_TOKEN"] = token
+        interval = os.environ.get("CLAUSIUS_MONITOR_INTERVAL", "")
+        if interval:
+            env["CLAUSIUS_MONITOR_INTERVAL"] = interval
+        try:
+            from nemo_skills.clausius_sdk.session import ClausiusSession
+
+            session = ClausiusSession.get()
+            if session:
+                env["CLAUSIUS_RUN_UUID"] = session.run_uuid
+        except Exception:
+            pass
+    return env
+
+
+_CLAUSIUS_MONITOR_SCRIPT = r'''
+python3 -c '
+import os,json,time,subprocess,urllib.request,signal,sys
+url=os.environ.get("CLAUSIUS_URL","")
+if not url:sys.exit(0)
+token=os.environ.get("CLAUSIUS_TOKEN","")
+ruuid=os.environ.get("CLAUSIUS_RUN_UUID","")
+jid=os.environ.get("SLURM_JOB_ID","unknown")
+iv=int(os.environ.get("CLAUSIUS_MONITOR_INTERVAL","60"))
+seq=0
+stop=False
+def _stop(*a):
+    global stop;stop=True
+signal.signal(signal.SIGTERM,_stop)
+signal.signal(signal.SIGINT,_stop)
+while not stop:
+    time.sleep(iv)
+    if stop:break
+    try:
+        out=subprocess.check_output(["nvidia-smi","--query-gpu=index,utilization.gpu,memory.used,memory.total,temperature.gpu","--format=csv,noheader,nounits"],text=True,timeout=10)
+        gpus=[]
+        for ln in out.strip().splitlines():
+            p=[x.strip() for x in ln.split(",")]
+            if len(p)>=5:gpus.append({"index":p[0],"util":float(p[1]),"mem_used":float(p[2]),"mem_total":float(p[3]),"temp":float(p[4])})
+        if not gpus:continue
+        seq+=1
+        ev=[{"run_uuid":ruuid,"event_type":"metric_logged","event_seq":10000+seq,"ts":time.time(),"payload":{"key":"gpu_telemetry","value":gpus,"step":seq,"context":{"slurm_job_id":jid,"source":"monitor"}}}]
+        body=json.dumps(ev).encode()
+        hdrs={"Content-Type":"application/json"}
+        if token:hdrs["Authorization"]=f"Bearer {token}"
+        rq=urllib.request.Request(f"{url}/api/sdk/events",data=body,headers=hdrs,method="POST")
+        urllib.request.urlopen(rq,timeout=5)
+    except Exception:pass
+' &
+CLAUSIUS_MONITOR_PID=$!
+'''
+
+_CLAUSIUS_REPORT_EXIT = r'''
+_CLAUSIUS_CMD_EXIT=$?
+kill $CLAUSIUS_MONITOR_PID 2>/dev/null; wait $CLAUSIUS_MONITOR_PID 2>/dev/null
+python3 -c "
+import os,json,time,urllib.request,sys
+url=os.environ.get('CLAUSIUS_URL','')
+if not url:sys.exit(0)
+token=os.environ.get('CLAUSIUS_TOKEN','')
+ruuid=os.environ.get('CLAUSIUS_RUN_UUID','')
+jid=os.environ.get('SLURM_JOB_ID','unknown')
+ec=$_CLAUSIUS_CMD_EXIT
+state='COMPLETED' if ec==0 else 'FAILED'
+try:
+    ev=[{'run_uuid':ruuid,'event_type':'job_state','event_seq':20000,'ts':time.time(),'payload':{'slurm_job_id':jid,'state':state,'exit_code':ec,'source':'wrapper'}}]
+    body=json.dumps(ev).encode()
+    hdrs={'Content-Type':'application/json'}
+    if token:hdrs['Authorization']=f'Bearer {token}'
+    rq=urllib.request.Request(f'{url}/api/sdk/events',data=body,headers=hdrs,method='POST')
+    urllib.request.urlopen(rq,timeout=10)
+except Exception:pass
+" 2>/dev/null
+exit $_CLAUSIUS_CMD_EXIT
+'''
+
+
+def _clausius_monitor_wrap(cmd):
+    """Wrap a command with background GPU monitor + exit-status reporter.
+
+    The monitor collects nvidia-smi telemetry in the background.
+    After the main command exits, the reporter POSTs a job_state event
+    with the exit code (COMPLETED/FAILED) before the container shuts down.
+    """
+    if not os.environ.get("CLAUSIUS_URL"):
+        return cmd
+    return (
+        _CLAUSIUS_MONITOR_SCRIPT.strip()
+        + "\n"
+        + cmd
+        + "\n"
+        + _CLAUSIUS_REPORT_EXIT.strip()
+    )
+
