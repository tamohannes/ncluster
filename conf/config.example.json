{
  "port": 7272,
  "log_search_bases": [
    "/shared/storage/users/$USER"
  ],
  "nemo_run_bases": [
    "/shared/storage/users/$USER/nemo-run"
  ],
  "mount_lustre_prefixes": [
    "shared/storage/users"
  ],
  "local_process_filters": {
    "include": [
      "my-framework", "my_framework",
      "python -m my_framework"
    ],
    "exclude": [
      "cursor", "jupyter", "ipykernel",
      "code-server"
    ]
  },
  "clusters": {
    "my-cluster": {
      "host": "login-node.example.com",
      "port": 22,
      "gpu_type": "H100",
      "mount_paths": [
        "/shared/storage/users/$USER"
      ]
    },
    "another-cluster": {
      "host": "login.another.example.com",
      "port": 22,
      "gpu_type": "A100",
      "mount_paths": [
        "/lustre/fsw/portfolios/my-team/users/$USER"
      ]
    }
  }
}
