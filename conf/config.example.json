{
  "port": 7272,
  "log_search_bases": [
    "/shared/storage/users/$USER"
  ],
  "nemo_run_bases": [
    "/shared/storage/users/$USER/nemo-run"
  ],
  "mount_lustre_prefixes": [
    "shared/storage/users"
  ],
  "local_process_filters": {
    "include": [
      "nemo-skills", "nemo_skills",
      "python -m nemo_skills"
    ],
    "exclude": [
      "cursor", "jupyter", "ipykernel",
      "code-server"
    ]
  },
  "clusters": {
    "my-cluster": {
      "host": "login-node.example.com",
      "port": 22,
      "gpu_type": "H100",
      "remote_root": "/"
    },
    "another-cluster": {
      "host": "login.another.example.com",
      "port": 22,
      "gpu_type": "A100",
      "remote_root": "/lustre"
    }
  }
}
